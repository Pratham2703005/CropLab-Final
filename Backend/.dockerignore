# Virtual envs / caches
venv/
.venv/
__pycache__/
**/__pycache__/
*.pyc
cache/

# Secrets — NEVER baked into the image, so it is safe to push to Docker Hub.
# Supplied at runtime instead:
#   - docker-compose : env_file + the JSON volume mount
#   - ECS            : the deploy script injects them as task env vars
#   - docker run     : --env-file ./Backend/.env
.env
.env.example
earth-engine-service-account.json

# Misc
.git/
.gitignore
*.md
