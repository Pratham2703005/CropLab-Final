# ============================================================
# Frontend environment variables — copy to `.env` and fill in.
# Only VITE_* vars are exposed to the browser; they are baked in
# at build time (`vite build`), not read at runtime.
# ============================================================

# Environment
VITE_ENVIRONMENT=development
MODE=development

# API — base URL of the backend. With docker-compose use the host-mapped port.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=10000

# Map configuration
VITE_MAP_API_KEY=your_maptiler_api_key_here
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
VITE_MAP_DEFAULT_CENTER_LAT=27.15336
VITE_MAP_DEFAULT_CENTER_LNG=77.97307
VITE_MAP_DEFAULT_ZOOM=10

# Max area (hectares) a user can select on the map
VITE_MAX_AREA_HECTARES=1000

# Weather API
VITE_WEATHER_API_KEY=your_weather_api_key_here
VITE_WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_MOCK_DATA=false

# Application
VITE_APP_NAME=AgriculturePlatform
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@agriculture-platform.com
