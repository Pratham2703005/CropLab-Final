# Backend base URL.
# - Local dev: point straight at the running backend.
#       VITE_API_BASE_URL=http://localhost:8000
# - Production (Vercel): use the same-origin proxy "/api". vercel.json rewrites
#   /api/* to the backend, so the browser makes a same-origin request. This
#   avoids CORS and stops privacy blockers (Brave Shields, uBlock) from blocking
#   the cross-site call. Set VITE_API_BASE_URL=/api in the Vercel project env.
VITE_API_BASE_URL=http://localhost:8000
#100,000m = 10,000hectare -> 10m = 1hr
VITE_MAX_AREA_HECTARES=1000
# Map Configuration
VITE_MAP_API_KEY=your_maptiler_api_key
VITE_MAP_DEFAULT_CENTER_LAT=28.6139
VITE_MAP_DEFAULT_CENTER_LNG=77.209
VITE_MAP_DEFAULT_ZOOM=10
